# Template file for 'vuurmuur'
pkgname=vuurmuur
version=0.8.2
revision=5
build_style=gnu-configure
# Force installation to /usr
configure_args="--prefix=/usr --sysconfdir=/etc --localstatedir=/var"
hostmakedepends="pkg-config automake libtool"
# Dependencies used when using, dialog is optional is for wizard but not detect interface
depends="iptables iproute2 iptrafvol dialog logrotate"
short_desc="Powerful firewall manager built on top of iptables"
maintainer="Florin Tanasă <florin.tanasa@gmail.com>"
license="GPL-2.0-or-later"
homepage="https://www.vuurmuur.org"
distfiles="https://www.vuurmuur.org/releases/stable/${pkgname}-${version}.tar.gz"
checksum=6388c4df83b327603f632e15b3201c297247f91d8adcc49172675738b935a5b3
# Dependencies used when compiling
makedepends="libnetfilter_log-devel ncurses-devel libmnl-devel libnetfilter_conntrack-devel"

conf_files="/etc/vuurmuur/config.conf \
